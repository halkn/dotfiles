[user]
  name = halkn
  email = nhalkn0920@gmail.com
[status]
  showUntrackedFiles = all
[diff]
  colorMoved = default
[difftool]
  prompt = false
[merge]
  tool = codediff
  conflictstyle = diff3
[mergetool]
  prompt = false
[color]
  ui = true
[fetch]
  prune = true
[push]
  default = current
[include]
  path = ~/.gitconfig.local
[alias]
  st = status
  br = branch
  sw = switch
  co = checkout
  df = difftool
  diff-narrow = -c delta.side-by-side=false diff
[core]
  pager = delta
[interactive]
  diffFilter = delta --color-only
[delta]
  hunk-header-decoration-style = omit
  navigate = true
  line-numbers = true
  side-by-side = true
  word-diff-regex = \\S+
  file-style = bold yellow ul
  file-decoration-style = none
  blame-code-style = syntax
  hyperlinks = true

