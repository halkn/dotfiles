{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 14,
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "30000",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh * list *)",
      "Bash(gh * view *)",
      "Bash(gh * status *)",
      "Bash(gh * checks *)",
      "Bash(gh search *)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff *)",
      "Bash(uv run pyright *)",
      "Bash(uv tree *)",
      "Bash(uv lock --check *)",
      "Bash(uv audit *)",
      "Bash(uv export *)",
      "Bash(eza *)",
      "Bash(tree *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(ghq list *)",
      "Bash(which *)",
      "Bash(echo)",
      "Bash(echo *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(pwd)",
      "Bash(cd *)",
      "Bash(az repos list *)",
      "Bash(az repos show *)",
      "Bash(az repos pr list *)",
      "Bash(az repos pr show *)",
      "Bash(az pipelines list *)",
      "Bash(az pipelines show *)",
      "Bash(az pipelines runs list *)",
      "Bash(az pipelines runs show *)",
      "Bash(az boards work-item show *)",
      "Bash(az boards query *)",
      "Bash(az devops project list *)",
      "Bash(az devops project show *)",
      "Bash(az devops configure --list*)",
      "Bash(az devops invoke *)",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:docs.microsoft.com)",
      "WebFetch(domain:azure.microsoft.com)",
      "WebFetch(domain:docs.snowflake.com)",
      "WebFetch(domain:community.snowflake.com)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/id_ecdsa*)",
      "Read(**/.ssh/**)",
      "Bash(dd*)",
      "Bash(shred*)",
      "Bash(truncate*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",
      "Bash(crontab*)",
      "Bash(sudo*)",
      "Bash(curl*)",
      "Bash(wget*)",
      "Bash(nc *)",
      "Bash(ssh*)",
      "Bash(scp*)",
      "Bash(python*)",
      "Bash(pip*)",
      "Bash(git checkout*)",
      "Bash(git reflog expire*)",
      "Bash(git gc --prune*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --delete*)",
      "Bash(git push * --delete*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(uv pip*)",
      "Bash(uvx*)",
      "Bash(uv tool run*)",
      "Bash(uv tool uninstall*)",
      "Bash(uv python uninstall*)",
      "Bash(uv cache clean*)",
      "Bash(uv cache prune*)",
      "Bash(uv self update*)",
      "Bash(uv add*)",
      "Bash(uv sync*)",
      "Bash(uv publish*)",
      "Bash(uv remove*)",
      "Bash(az devops invoke *--http-method post*)",
      "Bash(az devops invoke *--http-method POST*)",
      "Bash(az devops invoke *--http-method patch*)",
      "Bash(az devops invoke *--http-method PATCH*)",
      "Bash(az devops invoke *--http-method put*)",
      "Bash(az devops invoke *--http-method PUT*)",
      "Bash(az devops invoke *--http-method delete*)",
      "Bash(az devops invoke *--http-method DELETE*)"
    ],
    "ask": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(uv version*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-python.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-secret-read.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "tmux-agent-sidebar@hiroppy": true
  },
  "extraKnownMarketplaces": {
    "hiroppy": {
      "source": {
        "source": "directory",
        "path": "~/.local/share/tmux/plugins/tmux-agent-sidebar"
      }
    }
  },
  "viewMode": "verbose",
  "language": "japanese",
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "dev.azure.com",
        "*.dev.azure.com",
        "*.vssps.visualstudio.com",
        "login.microsoftonline.com"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.azure",
        "~/.cache/uv",
        "~/.local/share/uv",
        "~/.cache/mise",
        "~/.local/share/mise",
        "~/.local/state/mise"
      ],
      "denyWrite": [
        "~/.ssh",
        "~/.gnupg"
      ],
      "denyRead": [
        "~/"
      ],
      "allowRead": [
        ".",
        "~/.azure",
        "~/.claude/skills",
        "~/.config/git",
        "~/.config/gh",
        "~/.config/ripgrep",
        "~/.config/uv",
        "~/.local/share/uv",
        "~/.local/share/mise",
        "~/.config/mise",
        "~/.local/bin"
      ]
    }
  },
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "theme": "dark",
  "editorMode": "vim"
}
