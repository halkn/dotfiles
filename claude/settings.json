{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 14,
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "30000",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh * list *)",
      "Bash(gh * view *)",
      "Bash(gh * status *)",
      "Bash(gh * checks *)",
      "Bash(gh search *)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff *)",
      "Bash(uv run pyright *)",
      "Bash(uv tree *)",
      "Bash(uv lock --check *)",
      "Bash(uv audit *)",
      "Bash(uv export *)",
      "Bash(rg *)",
      "Bash(eza *)",
      "Bash(tree *)",
      "Bash(jq *)",
      "Bash(ghq list *)",
      "Bash(which *)",
      "Bash(az repos list *)",
      "Bash(az repos show *)",
      "Bash(az repos pr list *)",
      "Bash(az repos pr show *)",
      "Bash(az pipelines list *)",
      "Bash(az pipelines show *)",
      "Bash(az pipelines runs list *)",
      "Bash(az pipelines runs show *)",
      "Bash(az boards work-item show *)",
      "Bash(az boards query *)",
      "Bash(az devops project list *)",
      "Bash(az devops project show *)",
      "Bash(az devops configure --list*)",
      "Bash(az devops invoke *)",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:docs.microsoft.com)",
      "WebFetch(domain:azure.microsoft.com)",
      "WebFetch(domain:docs.snowflake.com)",
      "WebFetch(domain:community.snowflake.com)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(rm*)",
      "Bash(mv*)",
      "Bash(dd*)",
      "Bash(shred*)",
      "Bash(truncate*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",
      "Bash(crontab*)",
      "Bash(sudo*)",
      "Bash(curl*)",
      "Bash(wget*)",
      "Bash(nc *)",
      "Bash(ssh*)",
      "Bash(scp*)",
      "Bash(python*)",
      "Bash(pip*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git checkout*)",
      "Bash(git filter-branch*)",
      "Bash(git reflog expire*)",
      "Bash(git gc --prune*)",
      "Bash(git update-ref -d*)",
      "Bash(git config --global*)",
      "Bash(git config --unset*)",
      "Bash(git config --replace-all*)",
      "Bash(uv pip*)",
      "Bash(uvx*)",
      "Bash(uv tool run*)",
      "Bash(uv tool uninstall*)",
      "Bash(uv python uninstall*)",
      "Bash(uv cache clean*)",
      "Bash(uv cache prune*)",
      "Bash(uv self update*)",
      "Bash(az devops invoke *--http-method post*)",
      "Bash(az devops invoke *--http-method POST*)",
      "Bash(az devops invoke *--http-method patch*)",
      "Bash(az devops invoke *--http-method PATCH*)",
      "Bash(az devops invoke *--http-method put*)",
      "Bash(az devops invoke *--http-method PUT*)",
      "Bash(az devops invoke *--http-method delete*)",
      "Bash(az devops invoke *--http-method DELETE*)"
    ],
    "ask": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(uv add*)",
      "Bash(uv sync*)",
      "Bash(uv publish*)",
      "Bash(uv version*)",
      "Bash(uv remove*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "viewMode": "verbose",
  "language": "japanese",
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "pypi.org",
        "*.pypi.org",
        "files.pythonhosted.org",
        "dev.azure.com",
        "*.dev.azure.com",
        "login.microsoftonline.com",
        "learn.microsoft.com",
        "docs.microsoft.com",
        "azure.microsoft.com",
        "docs.snowflake.com",
        "community.snowflake.com"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.azure",
        "~/.cache/uv",
        "~/.local/share/uv"
      ],
      "denyWrite": [
        "~/.ssh",
        "~/.gnupg"
      ],
      "denyRead": [
        "~/"
      ],
      "allowRead": [
        ".",
        "~/.azure",
        "~/.config/git",
        "~/.config/gh",
        "~/.config/uv",
        "~/.cache/uv",
        "~/.local/share/uv",
        "~/.config/ripgrep",
        "~/.nix-profile",
        "/nix/store",
        "~/.local/bin"
      ]
    }
  },
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "theme": "dark",
  "editorMode": "vim"
}
