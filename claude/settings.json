{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 14,
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "30000",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git blame *)",
      "Bash(git ls-files *)",
      "Bash(git branch *)",
      "Bash(git switch *)",
      "Bash(git add *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr status *)",
      "Bash(gh pr checks *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(az repos list *)",
      "Bash(az repos show *)",
      "Bash(az repos pr list *)",
      "Bash(az repos pr show *)",
      "Bash(az pipelines list *)",
      "Bash(az pipelines show *)",
      "Bash(az pipelines runs list *)",
      "Bash(az pipelines runs show *)",
      "Bash(az boards work-item show *)",
      "Bash(az boards query *)",
      "Bash(az devops project list *)",
      "Bash(az devops project show *)",
      "Bash(az devops configure --list*)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff *)",
      "Bash(uv run pyright *)",
      "Bash(uv version *)",
      "Bash(rg *)",
      "Bash(eza *)",
      "Bash(tree *)",
      "Bash(jq *)",
      "Bash(ghq list *)",
      "Bash(which *)",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:docs.microsoft.com)",
      "WebFetch(domain:azure.microsoft.com)",
      "WebFetch(domain:docs.snowflake.com)",
      "WebFetch(domain:community.snowflake.com)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(rm*)",
      "Bash(mv*)",
      "Bash(dd*)",
      "Bash(shred*)",
      "Bash(truncate*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",
      "Bash(crontab*)",
      "Bash(sudo*)",
      "Bash(python*)",
      "Bash(pip*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git switch -C*)",
      "Bash(git switch --discard-changes*)",
      "Bash(git switch -f*)",
      "Bash(git switch --force*)",
      "Bash(git checkout*)",
      "Bash(git rm*)",
      "Bash(git restore .*)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)",
      "Bash(git branch -D*)",
      "Bash(git branch -M*)",
      "Bash(git branch -f*)",
      "Bash(git tag -d*)",
      "Bash(git tag --delete*)",
      "Bash(git stash drop*)",
      "Bash(git stash clear*)",
      "Bash(git filter-branch*)",
      "Bash(git reflog expire*)",
      "Bash(git gc --prune*)",
      "Bash(git update-ref -d*)",
      "Bash(git worktree remove*)",
      "Bash(git worktree prune*)",
      "Bash(git config --global*)",
      "Bash(git config --unset*)",
      "Bash(git config --replace-all*)",
      "Bash(uv pip*)",
      "Bash(uv remove*)",
      "Bash(uvx*)",
      "Bash(uv tool run*)",
      "Bash(uv tool uninstall*)",
      "Bash(uv python uninstall*)",
      "Bash(uv cache clean*)",
      "Bash(uv cache prune*)",
      "Bash(uv self update*)"
    ],
    "ask": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git restore*)",
      "Bash(git reset*)",
      "Bash(git rebase*)",
      "Bash(git merge*)",
      "Bash(uv add*)",
      "Bash(uv sync*)",
      "Bash(uv publish*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "viewMode": "verbose",
  "language": "japanese",
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "pypi.org",
        "*.pypi.org",
        "files.pythonhosted.org",
        "dev.azure.com",
        "*.dev.azure.com",
        "login.microsoftonline.com",
        "learn.microsoft.com",
        "docs.microsoft.com",
        "azure.microsoft.com",
        "docs.snowflake.com",
        "community.snowflake.com"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.cache/uv",
        "~/.local/share/uv",
        "~/.dotfiles/claude"
      ],
      "denyWrite": [
        "~/.ssh",
        "~/.gnupg"
      ],
      "denyRead": [
        "~/"
      ],
      "allowRead": [
        ".",
        "~/.gitconfig",
        "~/.gitconfig.local",
        "~/.config/git",
        "~/.config/gh",
        "~/.azure",
        "~/.local/bin",
        "~/.nix-profile",
        "~/.dotfiles/claude"
      ]
    }
  },
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "theme": "dark",
  "editorMode": "vim"
}
