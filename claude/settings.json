{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "fileSuggestion": {
    "type": "command",
    "command": "~/.claude/file-suggestion.sh"
  },
  "cleanupPeriodDays": 14,
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "30000",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_DISABLE_MOUSE_CLICKS": "1",
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh * list *)",
      "Bash(gh * view *)",
      "Bash(gh * status *)",
      "Bash(gh * checks *)",
      "Bash(gh search *)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff *)",
      "Bash(uv run pyright *)",
      "Bash(uv tree *)",
      "Bash(uv lock --check *)",
      "Bash(uv audit *)",
      "Bash(uv export *)",
      "Bash(eza *)",
      "Bash(tree *)",
      "Bash(jaq *)",
      "Bash(jq *)",
      "Bash(ghq list *)",
      "Bash(which *)",
      "Bash(echo)",
      "Bash(echo *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(pwd)",
      "Bash(cd *)",
      "Bash(az repos list *)",
      "Bash(az repos show *)",
      "Bash(az repos pr list *)",
      "Bash(az repos pr show *)",
      "Bash(az pipelines list *)",
      "Bash(az pipelines show *)",
      "Bash(az pipelines runs list *)",
      "Bash(az pipelines runs show *)",
      "Bash(az boards work-item show *)",
      "Bash(az boards query *)",
      "Bash(az devops project list *)",
      "Bash(az devops project show *)",
      "Bash(az devops configure --list*)",
      "Bash(az devops invoke *)",
      "Bash(gh pr create*)",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:docs.microsoft.com)",
      "WebFetch(domain:azure.microsoft.com)",
      "WebFetch(domain:docs.snowflake.com)",
      "WebFetch(domain:community.snowflake.com)"
    ],
    "deny": [
      "Read(//**/.env)",
      "Read(//**/.env.*)",
      "Read(//**/secrets/**)",
      "Read(//**/credentials/**)",
      "Read(//**/*.pem)",
      "Read(//**/*.key)",
      "Read(//**/*.p12)",
      "Read(//**/*.pfx)",
      "Read(//**/id_rsa*)",
      "Read(//**/id_ed25519*)",
      "Read(//**/id_ecdsa*)",
      "Read(//**/.ssh/**)",
      "Bash(dd*)",
      "Bash(shred*)",
      "Bash(truncate*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",
      "Bash(crontab*)",
      "Bash(sudo*)",
      "Bash(curl*)",
      "Bash(wget*)",
      "Bash(nc *)",
      "Bash(ssh*)",
      "Bash(scp*)",
      "Bash(python*)",
      "Bash(pip*)",
      "Bash(git checkout*)",
      "Bash(git reflog expire*)",
      "Bash(git gc --prune*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --delete*)",
      "Bash(git push * --delete*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git config *alias.*)",
      "Bash(uv pip*)",
      "Bash(uvx*)",
      "Bash(uv tool run*)",
      "Bash(uv tool uninstall*)",
      "Bash(uv python uninstall*)",
      "Bash(uv cache clean*)",
      "Bash(uv cache prune*)",
      "Bash(uv self update*)",
      "Bash(uv add*)",
      "Bash(uv sync*)",
      "Bash(uv publish*)",
      "Bash(uv remove*)",
      "Bash(mise run update)",
      "Bash(az devops invoke *--http-method post*)",
      "Bash(az devops invoke *--http-method POST*)",
      "Bash(az devops invoke *--http-method patch*)",
      "Bash(az devops invoke *--http-method PATCH*)",
      "Bash(az devops invoke *--http-method put*)",
      "Bash(az devops invoke *--http-method PUT*)",
      "Bash(az devops invoke *--http-method delete*)",
      "Bash(az devops invoke *--http-method DELETE*)"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push * main*)",
      "Bash(git push * master*)",
      "Bash(git remote add*)",
      "Bash(git remote set-url*)",
      "Bash(uv version*)"
    ],
    "defaultMode": "acceptEdits",
    "disableBypassPermissionsMode": "disable"
  },
  "autoMode": {
    "environment": [
      "$defaults",
      "Source control: github.com/halkn and repositories under it (personal projects and dotfiles)"
    ],
    "classifyAllShell": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-python.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-secret-read.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-main-push.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/scope-gh-pr-create.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "viewMode": "verbose",
  "language": "japanese",
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [
      "git *",
      "gh *"
    ],
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "dev.azure.com",
        "*.dev.azure.com",
        "*.vssps.visualstudio.com",
        "login.microsoftonline.com"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.azure",
        "~/.cache/uv",
        "~/.cache/mise",
        "~/.local/share/uv",
        "~/.local/share/mise",
        "~/.local/state/mise"
      ],
      "denyWrite": [
        "~/.ssh",
        "~/.gnupg"
      ],
      "denyRead": [
        "~/"
      ],
      "allowRead": [
        ".",
        "~/.azure",
        "~/.claude/skills",
        "~/.config",
        "~/.cache/uv",
        "~/.cache/mise",
        "~/.local/share/uv",
        "~/.local/share/mise",
        "~/.local/state/mise",
        "~/.local/bin"
      ]
    },
    "credentials": {
      "envVars": [
        {
          "name": "GH_TOKEN",
          "mode": "deny"
        },
        {
          "name": "GITHUB_TOKEN",
          "mode": "deny"
        },
        {
          "name": "AZURE_CLIENT_SECRET",
          "mode": "deny"
        },
        {
          "name": "SNOWFLAKE_PASSWORD",
          "mode": "deny"
        },
        {
          "name": "SNOWFLAKE_PRIVATE_KEY_PASSPHRASE",
          "mode": "deny"
        },
        {
          "name": "SNOWSQL_PWD",
          "mode": "deny"
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "mode": "deny"
        },
        {
          "name": "ANTHROPIC_AUTH_TOKEN",
          "mode": "deny"
        }
      ]
    }
  },
  "tui": "fullscreen",
  "theme": "dark",
  "editorMode": "vim"
}
