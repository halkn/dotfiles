# Standard development and GitHub collaboration operations can run without a
# sandbox escalation. Authentication, connection changes, and destructive
# operations remain subject to Codex approval.

prefix_rule(
    pattern = ["git", ["status", "diff", "log", "show"]],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "branch", "--show-current"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "add"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "switch", ["-f", "--force", "--discard-changes"]],
    decision = "prompt",
    justification = "未コミット変更を破棄する可能性があるため確認する。",
)

prefix_rule(
    pattern = ["git", "switch"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "push", ["-f", "--force", "--force-with-lease", "--delete", "--mirror"]],
    decision = "forbidden",
    justification = "リモートの履歴または ref を破壊・削除するため禁止する。通常の push を使用すること。",
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "リモートリポジトリを変更するため確認する。",
)

prefix_rule(
    pattern = ["git", "remote", "-v"],
    decision = "allow",
    match = ["git remote -v"],
    not_match = ["git remote set-url origin git@github.com:owner/repo.git"],
)

prefix_rule(
    pattern = ["git", "remote", "get-url"],
    decision = "allow",
    match = ["git remote get-url origin"],
    not_match = ["git remote set-url origin git@github.com:owner/repo.git"],
)

prefix_rule(
    pattern = ["git", "remote", ["add", "remove", "rename", "set-url"]],
    decision = "prompt",
    justification = "リモートの接続先または公開先を変更するため確認する。",
)

prefix_rule(
    pattern = ["git", ["restore", "reset"]],
    decision = "prompt",
    justification = "作業ツリーまたは履歴を変更・破棄する可能性があるため確認する。",
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "prompt",
    justification = "追跡されていないファイルを削除するため確認する。",
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "prompt",
    justification = "作業ツリーとステージ済みの変更を破棄するため確認する。",
)

prefix_rule(
    pattern = ["git", "checkout"],
    decision = "forbidden",
    justification = "Use `git switch` for branch changes or `git restore` for file restoration.",
)

# GitHub collaboration operations can run without a sandbox escalation.
# Authentication, repository deletion, and arbitrary API calls use the default
# approval flow.

prefix_rule(
    pattern = ["gh", "auth", "status"],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "auth"],
    decision = "prompt",
    justification = "GitHub の認証情報または認可状態を変更する可能性があるため確認する。",
)

prefix_rule(
    pattern = ["gh", "repo", "view"],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "pr", ["list", "status", "view", "diff", "checks"]],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "pr", "create"],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "issue", ["list", "view"]],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "issue", "create"],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", ["pr", "issue"], ["edit", "close", "reopen", "comment"]],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "run", "rerun"],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "repo", "delete"],
    decision = "forbidden",
    justification = "リモートリポジトリを削除するため禁止する。GitHub 上で対象を確認して手動で操作すること。",
)

prefix_rule(
    pattern = ["gh", "run", ["list", "view"]],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "search"],
    decision = "allow",
)
