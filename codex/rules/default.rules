# Safe local Git operations can run without a sandbox escalation.
# Broader or destructive operations remain subject to Codex approval.

prefix_rule(
    pattern = ["git", ["status", "diff", "log", "show"]],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "branch", "--show-current"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "add"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "switch"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "switch", ["-f", "--force", "--discard-changes"]],
    decision = "forbidden",
    justification = "未コミット変更を破棄する可能性があるため禁止する。通常の `git switch` を使用すること。",
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "prompt",
    justification = "Git hook の実行とローカル履歴の変更を伴うため確認する。",
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Push はリモートリポジトリを変更するため確認する。",
)

prefix_rule(
    pattern = ["git", "remote", "-v"],
    decision = "allow",
    match = ["git remote -v"],
    not_match = ["git remote set-url origin git@github.com:owner/repo.git"],
)

prefix_rule(
    pattern = ["git", "remote", "get-url"],
    decision = "allow",
    match = ["git remote get-url origin"],
    not_match = ["git remote set-url origin git@github.com:owner/repo.git"],
)

prefix_rule(
    pattern = ["git", ["restore", "reset"]],
    decision = "prompt",
    justification = "作業ツリーまたは履歴を変更・破棄する可能性があるため確認する。",
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "forbidden",
    justification = "追跡されていないファイルを削除するため禁止する。対象を確認して個別に削除すること。",
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "作業ツリーとステージ済みの変更を破棄するため禁止する。`git restore` などを対象を限定して使用すること。",
)

prefix_rule(
    pattern = ["git", "checkout"],
    decision = "forbidden",
    justification = "Use `git switch` for branch changes or `git restore` for file restoration.",
)

# Read-only GitHub CLI operations can run without a sandbox escalation.
# GitHub writes, authentication changes, and arbitrary API calls use the default
# approval flow.

prefix_rule(
    pattern = ["gh", "auth", "status"],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "repo", "view"],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "pr", ["list", "status", "view", "diff", "checks"]],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "pr", "create"],
    decision = "prompt",
    justification = "Draft を含め、PR の作成はリモート更新、通知、CI 実行を伴うため確認する。",
    match = ["gh pr create --draft --fill"],
)

prefix_rule(
    pattern = ["gh", "issue", ["list", "view"]],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "issue", "create"],
    decision = "prompt",
    justification = "Issue の作成はリモート更新と通知を伴うため確認する。",
)

prefix_rule(
    pattern = ["gh", "repo", "delete"],
    decision = "forbidden",
    justification = "リモートリポジトリを削除するため禁止する。GitHub 上で対象を確認して手動で操作すること。",
)

prefix_rule(
    pattern = ["gh", "run", ["list", "view"]],
    decision = "allow",
)

prefix_rule(
    pattern = ["gh", "search"],
    decision = "allow",
)
